# ── Narrative — Local Environment Variables ──────────────────────────────────
# Copy this file to .env.local and fill in your key.
# .env.local is gitignored by default in Next.js / Vercel projects.
# NEVER commit your actual key to GitHub.
#
# Get your key at: https://console.anthropic.com → API Keys

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Vercel Production ─────────────────────────────────────────────────────────
# In Vercel: Project → Settings → Environment Variables
# Add: ANTHROPIC_API_KEY = <your key>
# The key is injected at runtime — it never appears in your deployed code.
